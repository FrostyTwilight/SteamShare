<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SteamShare.UI.ViewModels"
             xmlns:ext="clr-namespace:SteamShare.UI.Converters"
             x:Class="SteamShare.UI.Views.TasksView"
             x:DataType="vm:TasksViewModel"
             x:CompileBindings="True"
             x:Name="Root">

    <UserControl.Resources>
        <ext:TaskStatusEqualsConverter x:Key="TaskStatusEquals" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*" Margin="16">
        <!-- ── Download Input Bar ── -->
        <Border Grid.Row="0"
                Padding="12"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                CornerRadius="8"
                Margin="0,0,0,12">
            <StackPanel Spacing="8">
                <TextBlock Text="{ext:Localize UI_Download_EnterShareKey}"
                           FontWeight="SemiBold"
                           FontSize="14" />
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                    <TextBox Grid.Row="0" Grid.Column="0"
                             Text="{Binding ShareKey}"
                             PlaceholderText="{ext:Localize UI_Download_ShareKeyWatermark}"
                             VerticalAlignment="Center"
                             IsEnabled="{Binding !IsLoading}" />
                    <TextBox Grid.Row="1" Grid.Column="0"
                             Text="{Binding Password}"
                             PasswordChar="*"
                             PlaceholderText="{ext:Localize UI_Download_PasswordOptional}"
                             VerticalAlignment="Center"
                             Margin="0,4,0,0"
                             IsEnabled="{Binding !IsLoading}" />
                    <StackPanel Grid.Column="1"
                                Grid.RowSpan="2"
                                Orientation="Horizontal"
                                Spacing="8"
                                Margin="8,0,0,0">
                        <Button Content="{ext:Localize Label_Download}"
                                Padding="16,8"
                                Command="{Binding StartDownloadCommand}"
                                IsEnabled="{Binding !IsLoading}" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ── Task Lists ── -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="12">
                <!-- Active Tasks -->
                <Border Padding="12"
                        Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                        CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{ext:Localize Label_ActiveTasks}"
                                   FontWeight="SemiBold"
                                   FontSize="14" />

                        <ItemsControl ItemsSource="{Binding ActiveTasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:TaskItemViewModel">
                                    <Border Padding="8"
                                            Margin="0,2"
                                            Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                            CornerRadius="6">
                                        <StackPanel Spacing="4">
                                            <!-- Row: Description + Status + Cancel -->
                                            <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto">
                                                <Border Grid.Column="0"
                                                        Padding="4,2"
                                                        Background="Transparent"
                                                        Tapped="OnTaskDescriptionTapped"
                                                        Cursor="Hand">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Text="{ext:Localize Label_Expand}"
                                                                   IsVisible="{Binding Children.Count}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                                        <TextBlock Text="{Binding Description}"
                                                                   FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Border>

                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Status}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0" />

                                                <Button Grid.Column="2"
                                                        Content="{ext:Localize Label_Cancel}"
                                                        Padding="8,4"
                                                        VerticalAlignment="Center"
                                                        Command="{Binding CancelCommand}"
                                                        IsVisible="False" />
                                            </Grid>

                                            <!-- Progress Bar -->
                                            <ProgressBar Value="{Binding Progress}"
                                                         Maximum="100"
                                                         Height="6"
                                                         IsVisible="{Binding Status, Converter={StaticResource TaskStatusEquals}, ConverterParameter=Running}"
                                                         ShowProgressText="True"
                                                         ProgressTextFormat="{}{0:0}%" />

                                            <!-- Progress Text (when not Running) -->
                                            <TextBlock Text="{Binding ProgressText}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                       TextTrimming="CharacterEllipsis" />

                                            <!-- Error Info -->
                                            <Border Padding="6,4"
                                                    Background="{DynamicResource SystemFillColorCriticalBackgroundBrush}"
                                                    CornerRadius="4"
                                                    IsVisible="{Binding HasError}">
                                                <TextBlock Text="{Binding LastException}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </Border>

                                            <!-- Timing Info -->
                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <TextBlock Text="{Binding StartTime, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                                <TextBlock Text="{Binding EndTime, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                            </StackPanel>

                                            <!-- Children (expandable) -->
                                            <ItemsControl ItemsSource="{Binding Children}"
                                                          IsVisible="{Binding IsExpanded}"
                                                          Margin="8,4,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:TaskItemViewModel">
                                                        <Border Padding="6,4"
                                                                Margin="0,2"
                                                                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                                                CornerRadius="4">
                                                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                                                <TextBlock Grid.Row="0" Grid.Column="0"
                                                                           Text="{Binding Description}"
                                                                           FontSize="12"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Grid.Row="0" Grid.Column="1"
                                                                           Text="{Binding Status}"
                                                                           FontSize="11"
                                                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                                           Margin="8,0,0,0"
                                                                           VerticalAlignment="Center" />
                                                                <ProgressBar Grid.Row="1" Grid.ColumnSpan="2"
                                                                             Value="{Binding Progress}"
                                                                             Maximum="100"
                                                                             Height="4"
                                                                             Margin="0,3,0,0"
                                                                             ShowProgressText="True"
                                                                             ProgressTextFormat="{}{0:0}%" />
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty state -->
                        <TextBlock Text="{ext:Localize UI_Tasks_NoActiveTasks}"
                                   IsVisible="{Binding !ActiveTasks.Count}"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,8" />
                    </StackPanel>
                </Border>

                <!-- Completed Tasks -->
                <Border Padding="12"
                        Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                        CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{ext:Localize Label_CompletedTasks}"
                                   FontWeight="SemiBold"
                                   FontSize="14" />

                        <ItemsControl ItemsSource="{Binding CompletedTasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:TaskItemViewModel">
                                    <Border Padding="8"
                                            Margin="0,2"
                                            Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                            CornerRadius="6">
                                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                            <TextBlock Grid.Row="0" Grid.Column="0"
                                                       Text="{Binding Description}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />
                                            <Border Grid.Row="0" Grid.Column="1"
                                                    Padding="6,2"
                                                    Background="{DynamicResource SystemFillColorSuccessBackgroundBrush}"
                                                    CornerRadius="4"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Status}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource SystemFillColorSuccessBrush}" />
                                            </Border>
                                            <TextBlock Grid.Row="1" Grid.ColumnSpan="2"
                                                       Text="{Binding EndTime, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                       Margin="0,3,0,0" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty state -->
                        <TextBlock Text="{ext:Localize UI_Tasks_NoCompletedTasks}"
                                   IsVisible="{Binding !CompletedTasks.Count}"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,8" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
